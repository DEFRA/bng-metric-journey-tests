# BNG Metric Frontend — service-specific environment variables
# Generic infrastructure vars (Mongo, Redis, AWS) are in defaults.env

# Backend URL — references the backend service by its compose service name
BACKEND_URL=http://bng-metric-backend:3001

# CDP Uploader URL — update if cdp-uploader is added to compose.yml
CDP_UPLOADER_URL=http://cdp-uploader:7337

# Session configuration
# IMPORTANT: replace with a real secret before running in any shared environment
SESSION_SECRET=replace-me-with-a-real-secret-min-32-chars

# Set to 'redis' to use the Redis session cache (recommended for multi-instance)
SESSION_CACHE_ENGINE=redis

# OpenID Connect — cdp-defra-id-stub for journey tests
# The frontend server calls the stub by its Docker service name (container-to-container).
# The browser route interceptor in auth.setup.js rewrites cdp-defra-id-stub:3200
# to localhost:3200 so the browser can reach the stub via the exposed host port.
OIDC_DISCOVERY_URL=http://cdp-defra-id-stub:3200/cdp-defra-id-stub/.well-known/openid-configuration
OIDC_CLIENT_ID=63983fc2-cfff-45bb-8ec2-959e21062b9a
OIDC_CLIENT_SECRET=test_value
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/auth/signed-out
OIDC_USE_STUB=true
