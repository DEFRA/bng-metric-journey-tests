# BNG Metric Backend — service-specific environment variables
# Generic infrastructure vars (Mongo, Redis, AWS) are in defaults.env

# PostgreSQL connection
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bng_metric_backend
DB_USER=dev
DB_LOCAL_PASSWORD=dev
# Disable IAM/SSL — plain postgres container does not support SSL
DB_IAM_AUTHENTICATION=false

# OpenID Connect — cdp-defra-id-stub for journey tests.
# The backend validates the forwarded Defra ID bearer against this discovery
# document when persisting the session (BMD-511). It must match the frontend's
# OIDC_DISCOVERY_URL; without it the bearer can't be verified, session persist
# returns 401, and the user falls back to unverified claims and is treated as
# lacking the bng completer role.
OIDC_DISCOVERY_URL=http://cdp-defra-id-stub:3200/cdp-defra-id-stub/.well-known/openid-configuration

# CDP Uploader URL
CDP_UPLOADER_URL=http://cdp-uploader:7337

# S3 bucket for baseline file uploads
CDP_UPLOADER_BUCKET=baseline-files
