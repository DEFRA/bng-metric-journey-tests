{
  "compilerOptions": {
    "target": "es2020",
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "paths": {
      "~/*": ["./*"],
      "@pages/*": ["./test/pages/*"],
      "@flows/*": ["./test/flows/*"],
      "@fixtures": ["./test/fixtures/index.js"],
      "@utils/*": ["./test/utils/*"]
